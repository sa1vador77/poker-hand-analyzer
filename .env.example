# Живая калибровка покерных констант под пул — БЕЗ правки кода и коммитов.
#
# Скопируй в `.env` (он в .gitignore) и меняй значения; пустой/отсутствующий ключ →
# берётся дефолт из config.py. Формат: KEY=VALUE, строки с `#` — комментарии.
# Значения ниже = текущие дефолты (под лузово-пассивный пул, VPIP ~50–83%).
# После правки .env — просто перезапусти анализ (config читается при импорте).

# --- Базовые диапазоны оппонента по тиру действия (нотация "TT+, AQs+") -------
# Раздвинуты под лузовый пул: тайтовый агрессор/коллер занижал число рук → перефолд.
OPP_AGGRESSOR=66+, A8s+, KTs+, QTs+, J9s+, T9s, 98s, AJo+, KQo
OPP_CALLER=22+, A2s+, K7s+, Q8s+, J8s+, T7s+, 96s+, 86s+, 75s+, 65s, 54s, A7o+, K9o+, QTo+, JTo
OPP_DEFAULT=22+, A2s+, K4s+, Q6s+, J7s+, T6s+, 96s+, 85s+, 74s+, 64s+, 53s+, A2o+, K7o+, Q8o+, J8o+, T8o+, 98o
OPP_JAMMER=22+, A2s+, A5o+, K7s+, K9o+, Q8s+, QTo+, J8s+, JTo, T8s+, 97s+, 87s, 76s
# Узкий ВЭЛЬЮ — с чем пул ДОБРОВОЛЬНО заходит ВСЕМ СТЕКОМ (гейт коммита + мультивей-олл-ин).
OPP_STACKOFF=99+, ATs+, KQs, AJo+

# --- Базовые диапазоны по ПРЕФЛОП-КОНТЕКСТУ (точнее тира: опен/3бет/лимп/защита) --
# Выбираются по первому добровольному действию оппонента + позиции; unknown → тир выше.
OPP_OPEN_EARLY=55+, A9s+, KTs+, QTs+, JTs, T9s, AJo+, KQo
OPP_OPEN_LATE=22+, A2s+, K7s+, Q8s+, J8s+, T8s+, 97s+, 86s+, 76s, 65s, 54s, A7o+, K9o+, QTo+, JTo
OPP_THREEBET=88+, ATs+, KJs+, QJs, A5s, A4s, AJo+, KQo
OPP_CALL_VS_OPEN=22+, A2s+, K9s+, Q9s+, J9s+, T8s+, 98s, 87s, 76s, ATo+, KJo+, QJo
OPP_LIMP=22+, A2s+, K2s+, Q5s+, J6s+, T6s+, 95s+, 85s+, 74s+, 64s+, 53s+, A2o+, K6o+, Q7o+, J7o+, T7o+, 97o+, 87o, 76o
OPP_BB_DEFEND=22+, A2s+, K2s+, Q4s+, J5s+, T6s+, 95s+, 84s+, 74s+, 63s+, 53s+, 43s, A2o+, K5o+, Q7o+, J7o+, T7o+, 97o+, 86o+, 76o, 65o

# --- Пороги сужения «продолжающего» диапазона по улицам (флоп,тёрн,ривер) -----
# Ниже = диапазон оппонента ШИРЕ (его агрессия стоит меньше) = меньше перефолда.
NARROW_AGGRESSOR=0.50,0.56,0.62
NARROW_CALLER=0.40,0.45,0.50

# --- Постфлоп-реализм -----------------------------------------------------------
BET_POLARIZATION=0.12     # +порог за размер ставки сверх 0.5 банка (выше = пугливее к овербетам)
DOMINATION_CRUSH=0.15     # экв героя vs комбо ниже этого = он мёртв против него
DOMINATION_PENALTY=0.6    # сила штрафа доминации (выше = чаще фолдит доминированные готовые руки)

# --- Реализация эквити по УЛИЦЕ (множитель R: флоп,тёрн,ривер) -------------------
# Растёт к риверу (шоудаун — рука забирает всю эквити). Для лузово-пассивного пула
# кривая пологая и высокая (он редко выбивает): флоп ×1.0 (без регресса), тёрн/ривер ↑
# мягко тянут к полной реализации = меньше перефолда готовых рук «впереди» на поздних
# улицах. Круче (флоп 0.84…) = осторожнее против АГРЕССИВНОГО пула, который выбивает.
REALIZATION_STREET=1.0,1.02,1.05

# --- Мультивей-ВЭЛЬЮ-БЕТ на инициативе (to_call=0, постфлоп) ---------------------
# Вэлью-бетим готовые топ-пара+/оверпара/две пары+ при реализованной эквити ≥ порога (БЕЗ
# опоры на fold-equity: пул не фолдит). Порог ВЫВЕДЕН ИЗ ЭКВИТИ-МАТЕМАТИКИ: против N коллеров
# вэлью-бет +EV при eq > 1/(N+1) (каждый доплачивает) → threshold = max(floor, 1/(N+1)+margin).
# Прежний линейный base−relief·(N−1) падал слишком медленно (N=3 → 0.46 вместо 1/4) и системно
# недо-бетил мультивей. margin откалиброван scripts/tune_value_thresholds.py (плато [0.00,0.06]).
MW_VALUE_MARGIN=0.06      # запас над break-even 1/(N+1) за reverse implied odds; ВЫШЕ = строже
MW_VALUE_FLOOR=0.22       # абсолютный пол порога (не бьём тотальный мусор)
MW_VALUE_SIZE_TOP=0.5     # доля банка для топ-пары/оверпары
MW_VALUE_SIZE_STRONG=0.66 # доля банка для двух пар+

# --- Текстура доски (engine/texture.py): поправка к порогу сужения --------------
# Отрицательная = шире (мокрый борд, пул продолжает с дро); положительная = уже.
TEXTURE_WET=-0.06         # монотон / 3-флеш / связка
TEXTURE_SEMI_WET=-0.03    # две масти или связная
TEXTURE_DRY=0.02          # радуга, несвязная
TEXTURE_CAP=0.07          # потолок |поправки|

# --- Линия оппонента (баррели/чек-рейз/донк) ------------------------------------
LINE_BARREL=0.05          # каждый доп. баррель сужает
LINE_CHECK_RAISE=0.10     # чек-рейз — сильная линия
LINE_DONK_RELIEF=0.03     # донк — чуть шире
LINE_CAP=0.15             # потолок добавки

# --- Профили игроков (лузовость per-opponent) -----------------------------------
POOL_VPIP=0.55            # средняя лузовость пула (центр; замер 50–83%)
PROFILE_SHRINK_HANDS=10   # до скольки рук профиль почти не влияет
PROFILE_NARROW_SCALE=0.3  # сила поправки за отклонение от пула
PROFILE_NARROW_CAP=0.06   # кап поправки профиля

# --- Префлоп --------------------------------------------------------------------
JAM_BB_THRESHOLD=15.0     # рейз ≥ стольких ББ = шов (пуш-диапазон)
PREFLOP_ODDS_MARGIN=0.0   # буфер для колла вне чарта по прямым шансам банка
SET_MINE_MAX_FRAC=0.07    # карманную пару vs ОДИН рейз коллим, если цена ≤ этой доли стека (сет-майн; 0=выкл)
PREMIUM_FLOOR=TT+, AQs+, AKo, AJs  # премиум при поз=— → рейз-для-вэлью, не фолд по сырой цене

# --- Гейт коммита (SPR-осознанность префлоп-рейза; нужен известный стек героя) --------------
# 3-бет, коммитящий стек, против НЕ-фолдящего пула = заход всем стеком: оправдан лишь при
# перевесе над OPP_STACKOFF. Лечит главный лик слива (лёгкий 3-бет-шов при низком SPR).
OPEN_RAISE_MULT=3.0       # оценка размера чарт-рейза без явного размера: 3× текущего уровня
COMMIT_RAISE_FRAC=0.5     # рейз ≥ этой доли эфф. стека = стек-офф (судится по эквити vs вэлью)
COMMIT_FLAT_FRAC=0.25     # колл ≥ этой доли стека = коммит-флэт (имплайдов нет; ВЫШЕ = мягче)
COMMIT_STACKOFF_MARGIN=0.0  # буфер сверх break-even, чтобы заходить стек-оффом (ВЫШЕ = реже коммитим)
